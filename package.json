{
  "name": "councilkit",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Local-first rooms for multi-agent decisions.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "@tanstack/react-query": "^5.59.0",
    "zustand": "^4.5.5",
    "dexie": "^4.0.8",
    "react-markdown": "^9.0.1",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "@vitejs/plugin-react": "^4.3.2",
    "tailwindcss": "^3.4.13",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20",
    "@biomejs/biome": "^1.9.2",
    "vitest": "^1.6.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/crypto-js": "^4.2.2"
  }
}
